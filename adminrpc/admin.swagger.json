          "format": "int64"
        }
      }
    },
    "adminrpcListTransactionsResponse": {
      "type": "object",
      "properties": {
        "transactions": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/adminrpcTransaction"
          }
        },
        "total_count": {
          "type": "string",
          "format": "int64"
        }
      }
    },
    "adminrpcRevokeTokenResponse": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string"
        }
      }
    },
    "adminrpcService": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "address": {
          "type": "string"
        },
        "protocol": {
          "type": "string"
        },
        "host_regexp": {
          "type": "string"
        },
        "path_regexp": {
          "type": "string"
        },
        "price": {
          "type": "string",
          "format": "int64"
        },
        "auth": {
          "type": "string"
        },
        "auth_scheme": {
          "$ref": "#/definitions/adminrpcAuthScheme",
          "description": "auth_scheme specifies which payment auth scheme(s) are used for this\nservice. Defaults to AUTH_SCHEME_L402 for backwards compatibility."
        },
        "timeout": {
          "type": "string",
          "format": "int64",
          "description": "timeout is the per-service TTL in seconds. When non-zero, the L402 mint\nwill include a _valid_until caveat so macaroons expire after this many\nseconds. A value of 0 means no expiry (no _valid_until caveat minted)."
        }
      }
    },
    "adminrpcServiceRevenue": {
      "type": "object",
      "properties": {
        "service_name": {
          "type": "string"
        },
        "total_revenue_sats": {
          "type": "string",
          "format": "int64"
        }
      }
    },
    "adminrpcTransaction": {
      "type": "object",
      "properties": {
        "id": {
          "type": "integer",
          "format": "int32"
        },
        "token_id": {
          "type": "string"
        },
        "payment_hash": {
          "type": "string"
        },
        "service_name": {
          "type": "string"
        },
        "price_sats": {
          "type": "string",
          "format": "int64"
        },
        "state": {
          "type": "string"
        },
        "created_at": {
          "type": "string"
        },
        "settled_at": {
          "type": "string"
        }
      }
    },
    "protobufAny": {
      "type": "object",
      "properties": {
        "@type": {
          "type": "string"
        }
      },
      "additionalProperties": {}
    },
    "rpcStatus": {
      "type": "object",
      "properties": {
        "code": {
          "type": "integer",
          "format": "int32"
        },
        "message": {
          "type": "string"
        },
        "details": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/protobufAny"
          }
        }
      }
    }
  }
