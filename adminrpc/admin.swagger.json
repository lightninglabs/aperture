          "format": "int64"
        },
        "service_breakdown": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/adminrpcServiceRevenue"
          }
        }
      }
    },
    "adminrpcListServicesResponse": {
      "type": "object",
      "properties": {
