  "definitions": {
    "adminrpcAuthScheme": {
      "type": "string",
      "enum": [
        "AUTH_SCHEME_L402",
        "AUTH_SCHEME_MPP",
        "AUTH_SCHEME_L402_MPP"
      ],
      "default": "AUTH_SCHEME_L402",
      "description": "AuthScheme specifies which payment authentication scheme(s) a service uses.\nL402 is the default for backwards compatibility with existing deployments.\n\n - AUTH_SCHEME_L402: AUTH_SCHEME_L402 is the default L402 (macaroon + preimage) scheme.\n - AUTH_SCHEME_MPP: AUTH_SCHEME_MPP is the Payment HTTP Authentication Scheme (charge\nintent only, no sessions).\n - AUTH_SCHEME_L402_MPP: AUTH_SCHEME_L402_MPP enables both L402 and MPP simultaneously. The\nproxy issues challenges for both schemes and accepts either."
    },
    "adminrpcCreateServiceRequest": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "address": {
          "type": "string"
        },
        "protocol": {
          "type": "string"
        },
        "host_regexp": {
          "type": "string"
        },
        "path_regexp": {
          "type": "string"
        },
        "price": {
          "type": "string",
          "format": "int64"
        },
        "auth": {
          "type": "string"
        },
        "auth_scheme": {
          "$ref": "#/definitions/adminrpcAuthScheme",
          "description": "auth_scheme specifies which payment auth scheme(s) to use. Defaults to\nAUTH_SCHEME_L402 if unset."
        },
        "timeout": {
          "type": "string",
          "format": "int64",
          "description": "timeout is the per-service TTL in seconds. See Service.timeout."
        }
      }
    },
    "adminrpcDeleteServiceResponse": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string"
        }
      }
    },
    "adminrpcGetHealthResponse": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string"
        }
      }
    },
    "adminrpcGetInfoResponse": {
      "type": "object",
      "properties": {
        "network": {
          "type": "string"
        },
        "listen_addr": {
          "type": "string"
        },
        "insecure": {
          "type": "boolean"
        },
        "mpp_enabled": {
          "type": "boolean",
          "description": "mpp_enabled indicates whether the MPP (Payment HTTP Auth Scheme) is\nenabled globally."
        },
        "sessions_enabled": {
          "type": "boolean",
          "description": "sessions_enabled indicates whether MPP session intents are enabled."
        },
        "mpp_realm": {
          "type": "string",
          "description": "mpp_realm is the realm string used in MPP challenge headers."
        }
      }
    },
    "adminrpcGetStatsResponse": {
      "type": "object",
      "properties": {
